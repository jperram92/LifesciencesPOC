<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Site coordinator access for Protocol Eligibility Screener: RSC custom fields, CareProgramEnrollee, Apex classes, and Flow launch.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <label>Clinical Trial Coordinator</label>

    <!-- ── Apex Class Access ─────────────────────────────────────── -->
    <classAccesses>
        <apexClass>ProtocolEligibilityScoringEngine</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>EligibilityAuditService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>ScreenerRequest</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>ScreenerResult</apexClass>
        <enabled>true</enabled>
    </classAccesses>

    <!-- ── Object Permissions ────────────────────────────────────── -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Account</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Contact</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>ResearchStudyCandidate</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>ResearchStudy</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>CareProgram</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>CareProgramEnrollee</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>DigitalSignature</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- ── Field Permissions — ResearchStudyCandidate custom fields ── -->
    <fieldPermissions>
        <editable>true</editable>
        <field>ResearchStudyCandidate.Disqualification_Reason__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <fieldPermissions>
        <editable>false</editable>
        <field>ResearchStudyCandidate.Protocol_Failure_Code__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <fieldPermissions>
        <editable>false</editable>
        <field>ResearchStudyCandidate.Screener_Version__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <fieldPermissions>
        <editable>false</editable>
        <field>ResearchStudyCandidate.Submission_Timestamp__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <fieldPermissions>
        <editable>false</editable>
        <field>ResearchStudyCandidate.Screener_JSON_Responses__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <!-- ── Field Permissions — CareProgramEnrollee standard fields ── -->
    <fieldPermissions>
        <editable>false</editable>
        <field>CareProgramEnrollee.Status</field>
        <readable>true</readable>
    </fieldPermissions>

    <fieldPermissions>
        <editable>false</editable>
        <field>CareProgramEnrollee.ResearchStudyCandidateId</field>
        <readable>true</readable>
    </fieldPermissions>

    <!-- ── Flow Access ───────────────────────────────────────────── -->
    <flowAccesses>
        <enabled>true</enabled>
        <flow>Clinical_Trial_Eligibility_Screener</flow>
    </flowAccesses>

    <!-- ── User Permissions ──────────────────────────────────────── -->
    <userPermissions>
        <enabled>true</enabled>
        <name>RunFlow</name>
    </userPermissions>

</PermissionSet>
