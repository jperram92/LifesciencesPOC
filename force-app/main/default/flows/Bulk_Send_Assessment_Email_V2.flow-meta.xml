    <decisions>
        <description>Check if Contact point Email is Set then use this email for further processing</description>
        <name>CheckIfContactPointEmailIsSet</name>
        <label>Check If Contact Point Email is Set</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>IterateThroughContactPointEmails</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>ContactPointEmailIsSet</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>IterateThroughContactPointEmails.EmailAddress</leftValueReference>
                <operator>WasSet</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>IterateThroughContactPointEmails.EmailAddress</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>AssignContactPointEmailToRecipientList</targetReference>
            </connector>
            <label>Contact Point Email is Set</label>
        </rules>
    </decisions>
    <decisions>
        <description>Check if experience cloud site URL is set, If it is not then error message will be set and flow will be updated</description>
        <name>CheckIfExperienceCouldSiteUrlIsSet</name>
        <label>Check if experience cloud site URL is set</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>SetExperienceSiteUrlErrorMessageAssignment</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>ExperienceCloudSiteURLIsSet</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ExperienceCloudSiteUrl</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>https://updatethisurl.internal.site.com/mypage</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>GetAssessmentEnvelopeRecords</targetReference>
            </connector>
            <label>Experience cloud site URL is set</label>
        </rules>
    </decisions>
    <decisions>
        <description>Check to send email only if at least one recipient is present</description>
        <name>CheckIfRecipientEmailSizeIsGreaterThanZero</name>
        <label>Check if Recipient Email Size is greater than zero</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>RecipientListEmptyErrorAssignment</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>RecipientEmailSizeIsGreaterThanZero</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>RecipientEmailCsv</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>SendAssessmentEmail</targetReference>
            </connector>
            <label>Recipient Email Size is greater than zero</label>
        </rules>
    </decisions>
    <decisions>
        <description>Check if there at least one account Id is present to get account details</description>
        <name>ChecksIfAccountIdsAreNotNull</name>
        <label>Checks if Account Ids are not null</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>CheckIfRecipientEmailSizeIsGreaterThanZero</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>AccountIdsAreNotNull</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>AccountIds</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>GetContactPointEmails</targetReference>
            </connector>
            <label>Account Ids Are not null</label>
        </rules>
    </decisions>
    <decisions>
        <description>Checks whether Account has person email Set</description>
        <name>DoesAccountHasPersonEmailSet</name>
        <label>Does Account has person Email Set ?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>LoopThroughAccountRecords</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>PersonEmailIsSet</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>LoopThroughAccountRecords.PersonEmail</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>LoopThroughAccountRecords.PersonEmail</leftValueReference>
                <operator>WasSet</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>AddEmailToRecipientEmailCSV</targetReference>
            </connector>
            <label>Person email is set</label>
        </rules>
    </decisions>
    <decisions>
        <description>Determines which Email Address to Consider based on whether contact is set or Account Contact point is set</description>
        <name>WhatRecordSetToAssessmentEnvelope</name>
        <label>What record Is set To Assessment Envelope ?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>IterateThroughEnvelopeRecords</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>ContactRecordIsSetToAssessmentEnvelope</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>IterateThroughEnvelopeRecords.ContactId</leftValueReference>
                <operator>StartsWith</operator>
                <rightValue>
                    <stringValue>003</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>IterateThroughEnvelopeRecords.Contact.Email</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>AddRecipientEmail</targetReference>
            </connector>
            <label>Contact Is Set To Assessment Envelope</label>
        </rules>
        <rules>
            <name>AccountIsSetToAssessmentEnvelope</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>IterateThroughEnvelopeRecords.AccountId</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>001</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>AddAccountIdToAccountIdsList</targetReference>
            </connector>
            <label>Account Record Set To Assessment Envelope</label>
        </rules>
    </decisions>
