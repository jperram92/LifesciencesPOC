<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <actionCalls>
        <description>Calls an action that generates and sends an email to recipient about Assessment that needs to be completed</description>
        <name>SendAssessmentEmail</name>
        <label>Send Assessment Email</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <actionName>emailSimple</actionName>
        <actionType>emailSimple</actionType>
        <connector>
            <targetReference>AssignSuccessMessage</targetReference>
        </connector>
        <faultConnector>
            <targetReference>SendAssessmentEmailErrorAssignment</targetReference>
        </faultConnector>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>emailAddresses</name>
            <value>
                <elementReference>$User.Email</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>emailSubject</name>
            <value>
                <stringValue>{!$Organization.Name}: You have a new Assessment to complete.</stringValue>
            </value>
        </inputParameters>
        <inputParameters>
            <name>emailBody</name>
            <value>
                <elementReference>EmailBodyTextTemplate</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>sendRichBody</name>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputParameters>
        <inputParameters>
            <name>bccRecipientAddressList</name>
            <value>
                <elementReference>RecipientEmailCsv</elementReference>
            </value>
        </inputParameters>
        <nameSegment>emailSimple</nameSegment>
        <offset>0</offset>
    </actionCalls>
    <apiVersion>64.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <description>Adds Account Id to Account Ids List which is further used in sending email notification.</description>
        <name>AddAccountIdToAccountIdsList</name>
        <label>Add Account Id to Account Ids List</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>AccountIds</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>IterateThroughEnvelopeRecords.AccountId</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>IterateThroughEnvelopeRecords</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Assign Email to Recipient EmailCSV</description>
        <name>AddEmailToRecipientEmailCSV</name>
        <label>Add Email to Recipient Email CSV</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>RecipientEmailCsv</assignToReference>
            <operator>Add</operator>
            <value>
                <stringValue>{!IterateThroughEnvelopeRecords.Contact.Email},</stringValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>LoopThroughAccountRecords</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Add Recipient Email from the contact</description>
        <name>AddRecipientEmail</name>
        <label>Add Recipient Email</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>RecipientEmailCsv</assignToReference>
            <operator>Add</operator>
            <value>
                <stringValue>{!IterateThroughEnvelopeRecords.Contact.Email},</stringValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>IterateThroughEnvelopeRecords</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Assign Contact point Email to Recipient List and also store account Ids for which contact point email is assigned</description>
        <name>AssignContactPointEmailToRecipientList</name>
        <label>Assign Contact point Email to Recipient List</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>AccountIds</assignToReference>
            <operator>RemoveAll</operator>
            <value>
                <elementReference>IterateThroughContactPointEmails.ParentId</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>RecipientEmailCsv</assignToReference>
            <operator>Add</operator>
            <value>
                <stringValue>{!IterateThroughEnvelopeRecords.Contact.Email},</stringValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>IterateThroughContactPointEmails</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>If everything goes well in the flow success message needs to be assigned</description>
        <name>AssignSuccessMessage</name>
        <label>Assign Success Message</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>isResponseSuccess</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>responseMessage</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>SendAssessmentEnvelopeSuccessMessage</elementReference>
            </value>
        </assignmentItems>
