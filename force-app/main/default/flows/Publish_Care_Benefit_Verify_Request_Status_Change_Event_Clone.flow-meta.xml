    <recordCreates>
        <description>Creates a care benefit verify request status changed event record, setting the Record Identifier to Care Benefit Verify Request ID, and status to ClearingHouseResponseReceivedEventStatus.</description>
        <name>CreateCareBenefitVerifyRequestStatusChangedEvent</name>
        <label>Create Care Benefit Verify Request Status Changed Event</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <faultConnector>
            <targetReference>SetErrorMessageClearingHouseResponseReceivedEventStatus</targetReference>
        </faultConnector>
        <inputAssignments>
            <field>RecordIdentifier</field>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Status</field>
            <value>
                <elementReference>ClearingHouseResponseReceivedEventStatus</elementReference>
            </value>
        </inputAssignments>
        <object>CareBnftVrfyRqstStsChgEvent</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordCreates>
    <recordCreates>
        <description>Creates a care benefit verify request status changed event record, setting the Record Identifier to Care Benefit Verify Request ID, and status to PatientDetailsUpdatedEventStatus.</description>
        <name>CreateCareBenefitVerifyRequestStatusChangedEventPatientDetailsUpdatedEventStatus</name>
        <label>Create Care Benefit Verify Request Status Changed Event</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <faultConnector>
            <targetReference>SetErrorMessagePatientDetailsUpdatedEventStatus</targetReference>
        </faultConnector>
        <inputAssignments>
            <field>RecordIdentifier</field>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Status</field>
            <value>
                <elementReference>PatientDetailsUpdatedEventStatus</elementReference>
            </value>
        </inputAssignments>
        <object>CareBnftVrfyRqstStsChgEvent</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordCreates>
    <recordCreates>
        <description>Creates a care benefit verify request status changed event record, setting the Record Identifier to Care Benefit Verify Request ID, and status to AssessmentSentToPatientEventStatus.</description>
        <name>CreateCareBenefitVerifyRequestStatusChangedEventPatientResponse</name>
        <label>Create Care Benefit Verify Request Status Changed Event</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <faultConnector>
            <targetReference>SetErrorMessageAssessmentSentToPatientEventStatus</targetReference>
        </faultConnector>
        <inputAssignments>
            <field>RecordIdentifier</field>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Status</field>
            <value>
                <elementReference>AssessmentSentToPatientEventStatus</elementReference>
            </value>
        </inputAssignments>
        <object>CareBnftVrfyRqstStsChgEvent</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordCreates>
    <sourceTemplate>BnftVerfAgnt__PubCrBnftVrfyRqstStsChg</sourceTemplate>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>WhatIsTheStatusOfPatientAndBenefitsDetails</targetReference>
        </connector>
        <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
        <filterLogic>1 OR 2 OR 3 OR 4 OR 5 OR 6</filterLogic>
        <filters>
            <field>Status</field>
            <operator>EqualTo</operator>
