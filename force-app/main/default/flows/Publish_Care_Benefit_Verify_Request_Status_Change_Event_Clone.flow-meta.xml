<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <constants>
        <description>Stores the text value of the event status when the assessment is sent to the patient. The default value is AssessmentSentToPatient.</description>
        <name>AssessmentSentToPatientEventStatus</name>
        <dataType>String</dataType>
        <value>
            <stringValue>AssessmentFormSentToPatient</stringValue>
        </value>
    </constants>
    <constants>
        <description>Stores the text value of the event status when ‌the response is received from the clearing house. The default value is ClearingHouseResponseReceived.</description>
        <name>ClearingHouseResponseReceivedEventStatus</name>
        <dataType>String</dataType>
        <value>
            <stringValue>ClearingHouseResponseReceived</stringValue>
        </value>
    </constants>
    <constants>
        <description>Stores the text value of the event status when the patient’s details are updated. The default value is PatientDetailsUpdated.</description>
        <name>PatientDetailsUpdatedEventStatus</name>
        <dataType>String</dataType>
        <value>
            <stringValue>PatientAssessmentResponseUpdatedToRecords</stringValue>
        </value>
    </constants>
    <customErrors>
        <description>Sets the error message that the flow returns when there’s an error creating the care benefit verify request status changed event record.</description>
        <name>SetErrorMessageAssessmentSentToPatientEventStatus</name>
        <label>Set Error Message</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <customErrorMessages>
            <errorMessage>{!CreateCBVRStatusUpdateEventErrorTextTemplate}</errorMessage>
            <isFieldError>false</isFieldError>
        </customErrorMessages>
    </customErrors>
    <customErrors>
        <description>Sets the error message that the flow returns when there’s an error creating the care benefit verify request status changed event record.</description>
        <name>SetErrorMessageClearingHouseResponseReceivedEventStatus</name>
        <label>Set Error Message</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <customErrorMessages>
            <errorMessage>{!CreateCBVRStatusUpdateEventErrorTextTemplate}</errorMessage>
            <isFieldError>false</isFieldError>
        </customErrorMessages>
    </customErrors>
    <customErrors>
        <description>Sets the error message that the flow returns when there’s an error creating the care benefit verify request status changed event record.</description>
        <name>SetErrorMessagePatientDetailsUpdatedEventStatus</name>
        <label>Set Error Message</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <customErrorMessages>
            <errorMessage>{!CreateCBVRStatusUpdateEventErrorTextTemplate}</errorMessage>
            <isFieldError>false</isFieldError>
        </customErrorMessages>
    </customErrors>
    <decisions>
        <description>Determines the status of a patient’s personal and healthcare details, and benefits details by checking the value of the Status field of the triggering record.</description>
        <name>WhatIsTheStatusOfPatientAndBenefitsDetails</name>
        <label>What Is the Status of Patient and Benefits Details?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Other (Default)</defaultConnectorLabel>
        <rules>
            <name>PatientDetailsUpdated</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ReadyForVerification</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.RelatedCareBnftVerifyRequestId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>CreateCareBenefitVerifyRequestStatusChangedEventPatientDetailsUpdatedEventStatus</targetReference>
            </connector>
            <label>Patient Details Updated</label>
        </rules>
        <rules>
            <name>ClearingHouseResponseReceived</name>
            <conditionLogic>1 AND (2 OR 3 OR 4 OR 5) AND 6</conditionLogic>
            <conditions>
                <leftValueReference>$Record__Prior.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Acknowledged</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Verified</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Rejected</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Error</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>TimedOut</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.RelatedCareBnftVerifyRequestId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>CreateCareBenefitVerifyRequestStatusChangedEvent</targetReference>
            </connector>
            <label>Clearing House Response Received</label>
        </rules>
        <rules>
            <name>Pending_Confirmation</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>PendingConfirmation</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.RelatedCareBnftVerifyRequestId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>CreateCareBenefitVerifyRequestStatusChangedEventPatientResponse</targetReference>
            </connector>
            <label>Pending Confirmation</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <interviewLabel>Publish Care Benefit Verify Request Status Change Event Clone {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Publish Care Benefit Verify Request Status Change Event Clone</label>
