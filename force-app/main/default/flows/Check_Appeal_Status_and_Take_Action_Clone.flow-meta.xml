<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>63.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <description>Sets canApplicationProcessingContinue to False.</description>
        <name>ResetVariableForContinuingApplicationProcessing</name>
        <label>Reset Variable for Continuing Application Processing</label>
        <locationX>248</locationX>
        <locationY>134</locationY>
        <assignmentItems>
            <assignToReference>canApplicationProcessingContinue</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>GetServiceCatalogRequestExtendedAttributeValues</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Sets AppealsFiledCount to the count of records in the Service Catalog Request Extended Attribute Values from Get Service Catalog Request Extended Attribute Values record collection.</description>
