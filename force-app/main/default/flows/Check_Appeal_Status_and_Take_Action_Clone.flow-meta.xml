        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <scale>0</scale>
    </variables>
    <variables>
        <description>Stores the total number of appeals filed for a program.</description>
        <name>AppealsFiledCount</name>
        <dataType>Number</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <scale>0</scale>
    </variables>
    <variables>
        <description>Stores the application form ID that was passed as an input to the flow.</description>
        <name>applicationFormId</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <description>Stores a boolean value that indicates whether the flow orchestrator should continue processing the application for the financial assistance program. This value is available as output from the flow.</description>
        <name>canApplicationProcessingContinue</name>
        <dataType>Boolean</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>true</isOutput>
    </variables>
    <variables>
        <description>Stores the Case ID associated with the service catalog request record.</description>
        <name>CaseId</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <description>Stores the program ID of the application form.</description>
        <name>ProgramId</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <description>Stores the Service Catalog Request ID of the latest services catalog extended attribute value.</description>
        <name>ServiceCatalogRequestId</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <description>Stores Service Catalog Extended Attribute Value Status</description>
        <name>SvcCatalogExtendedAttrValueStatus</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
    <waits>
        <description>Pauses the flow until the Application Form Appeal Status Change Event response is received where the AppealStatus is either Accepted or Rejected. When there is no response the failure output variables are set and the flow ends.</description>
        <name>WaitForAppealActionResponse</name>
        <label>Wait for Appeal Action Response</label>
        <locationX>710</locationX>
        <locationY>782</locationY>
        <defaultConnectorLabel>Other (Default)</defaultConnectorLabel>
        <waitEvents>
            <name>IsAccepted</name>
            <conditionLogic>and</conditionLogic>
            <connector>
                <targetReference>SetVariableToLetFlowContinue</targetReference>
            </connector>
            <eventType>ApplnFormAppealStsChgEvnt</eventType>
            <inputParameters>
                <name>ApplicationFormIdentifier</name>
                <value>
                    <elementReference>applicationFormId</elementReference>
                </value>
            </inputParameters>
            <inputParameters>
                <name>AppealStatus</name>
                <value>
                    <stringValue>Accepted</stringValue>
                </value>
            </inputParameters>
            <label>Appeal Accepted</label>
        </waitEvents>
        <waitEvents>
            <name>IsRejected</name>
            <conditionLogic>and</conditionLogic>
            <connector>
                <isGoTo>true</isGoTo>
                <targetReference>ResetVariableForContinuingApplicationProcessing</targetReference>
            </connector>
            <eventType>ApplnFormAppealStsChgEvnt</eventType>
            <inputParameters>
                <name>ApplicationFormIdentifier</name>
                <value>
                    <elementReference>applicationFormId</elementReference>
                </value>
            </inputParameters>
            <inputParameters>
                <name>AppealStatus</name>
                <value>
                    <stringValue>Rejected</stringValue>
                </value>
            </inputParameters>
            <label>Appeal Rejected</label>
        </waitEvents>
        <waitEvents>
            <name>IsTimedOut</name>
            <conditionLogic>and</conditionLogic>
            <connector>
                <targetReference>GetMostRecentServiceCatalogExtendedAttributeValues</targetReference>
            </connector>
            <eventType>DateRefAlarmEvent</eventType>
            <inputParameters>
                <name>TimeTableColumnEnumOrId</name>
                <value>
                    <stringValue>ApplicationForm</stringValue>
                </value>
            </inputParameters>
            <inputParameters>
                <name>TimeFieldColumnEnumOrId</name>
                <value>
                    <stringValue>CreatedDate</stringValue>
                </value>
            </inputParameters>
            <inputParameters>
                <name>EntityObjectId</name>
                <value>
                    <elementReference>applicationFormId</elementReference>
                </value>
            </inputParameters>
            <inputParameters>
                <name>TimeOffset</name>
                <value>
                    <numberValue>30.0</numberValue>
                </value>
            </inputParameters>
            <inputParameters>
                <name>TimeOffsetUnit</name>
                <value>
                    <stringValue>Days</stringValue>
                </value>
            </inputParameters>
            <label>Appeal Timed Out</label>
        </waitEvents>
    </waits>
</Flow>
