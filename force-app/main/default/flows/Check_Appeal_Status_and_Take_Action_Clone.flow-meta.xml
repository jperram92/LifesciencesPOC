        </outputAssignments>
        <sortField>Id</sortField>
        <sortOrder>Asc</sortOrder>
    </recordLookups>
    <recordLookups>
        <description>Gets the service catalog request extended attribute value records with ReferenceRecordId matching applicationFormId and SvcCtlgItemAttrDeveloperName matching ApplicationForm. Stores the ID, service catalog request ID, and created date of the results in Service Catalog Request Extended Attribute Values from Get Service Catalog Request Extended Attribute Values.</description>
        <name>GetServiceCatalogRequestExtendedAttributeValues</name>
        <label>Get Service Catalog Request Extended Attribute Values</label>
        <locationX>248</locationX>
        <locationY>242</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>GetApplicationFormRelation</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>ReferenceRecordId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>applicationFormId</elementReference>
            </value>
        </filters>
        <filters>
            <field>SvcCtlgItemAttrDeveloperName</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>ApplicationForm</stringValue>
            </value>
