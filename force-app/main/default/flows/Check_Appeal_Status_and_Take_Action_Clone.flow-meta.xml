    <recordUpdates>
        <description>Updates the case records with an ID matching CaseID, setting the status to Closed.</description>
        <name>UpdateCaseStatus</name>
        <label>Update Case Status</label>
        <locationX>578</locationX>
        <locationY>1538</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>CaseId</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Status</field>
            <value>
                <stringValue>Closed</stringValue>
            </value>
        </inputAssignments>
        <object>Case</object>
    </recordUpdates>
    <recordUpdates>
        <description>Updates the service catalog extended attribute value records with SvcCatalogRequestId matching ServiceCatalogRequestId and SvcCtlgItemAttrDeveloperName equal to Status, setting TextValue to Rejected Timeout.</description>
        <name>UpdateServiceCatalogRequestExtendedAttributeValue</name>
        <label>Update Service Catalog Request Extended Attribute Value</label>
        <locationX>578</locationX>
        <locationY>1430</locationY>
        <connector>
            <targetReference>UpdateCaseStatus</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>SvcCatalogRequestId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>ServiceCatalogRequestId</elementReference>
            </value>
        </filters>
        <filters>
            <field>SvcCtlgItemAttrDeveloperName</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Status</stringValue>
            </value>
        </filters>
        <inputAssignments>
            <field>TextValue</field>
            <value>
                <stringValue>Rejected Timeout</stringValue>
            </value>
        </inputAssignments>
        <object>SvcCatalogReqExtdAttrVal</object>
    </recordUpdates>
    <start>
        <locationX>122</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>ResetVariableForContinuingApplicationProcessing</targetReference>
        </connector>
    </start>
    <status>Active</status>
    <variables>
