        <label>Set Appeals Filed Count</label>
        <locationX>248</locationX>
        <locationY>566</locationY>
        <assignmentItems>
            <assignToReference>AppealsFiledCount</assignToReference>
            <operator>AssignCount</operator>
            <value>
                <elementReference>GetServiceCatalogRequestExtendedAttributeValues</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>IsAppealLimitExceeded</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Sets canApplicationProcessingContinue to True.</description>
        <name>SetVariableToLetFlowContinue</name>
        <label>Set Variable to Let Flow Continue</label>
        <locationX>50</locationX>
        <locationY>890</locationY>
        <assignmentItems>
            <assignToReference>canApplicationProcessingContinue</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
    </assignments>
    <decisions>
        <description>Determines whether appeals were filed for the application form by checking if AppealsFiledCount is greater than 0.</description>
        <name>AreAppealsFiledForApplicationForm</name>
        <label>Are Appeals Filed for Application Form?</label>
        <locationX>908</locationX>
        <locationY>998</locationY>
        <defaultConnectorLabel>No (Default)</defaultConnectorLabel>
        <rules>
            <name>HasAppealsFiled</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ServiceCatalogRequestId</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>GetServiceCatalogRequestExtendedAttributeStatusValue</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <description>Determines whether the appeal limit has been exceeded or not by checking if AppealsFiledCount is greater than AppealLimit.</description>
        <name>IsAppealLimitExceeded</name>
        <label>Is Appeal Limit Exceeded?</label>
        <locationX>248</locationX>
        <locationY>674</locationY>
        <defaultConnector>
            <targetReference>WaitForAppealActionResponse</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No (Default)</defaultConnectorLabel>
        <rules>
            <name>HasExceededAppealLimit</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>AppealsFiledCount</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>AppealLimit</elementReference>
                </rightValue>
            </conditions>
            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <description>Check if Service Catalog Extended Attribute Value Status is New</description>
        <name>IsServiceCatalogExtendedAttributeValueStatusNew</name>
        <label>Is Service Catalog Extended Attribute Value Status New?</label>
        <locationX>710</locationX>
        <locationY>1214</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>IsNew</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>SvcCatalogExtendedAttrValueStatus</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>New</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>GetServiceCatalogRequest</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <environments>Default</environments>
