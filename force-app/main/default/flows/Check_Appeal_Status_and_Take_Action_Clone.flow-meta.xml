    <recordLookups>
        <description>Get Service Catalog Request Extended Attribute Status Value</description>
        <name>GetServiceCatalogRequestExtendedAttributeStatusValue</name>
        <label>Get Service Catalog Request Extended Attribute Status Value</label>
        <locationX>710</locationX>
        <locationY>1106</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>IsServiceCatalogExtendedAttributeValueStatusNew</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>SvcCatalogRequestId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>ServiceCatalogRequestId</elementReference>
            </value>
        </filters>
        <filters>
            <field>SvcCtlgItemAttrDeveloperName</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Status</stringValue>
            </value>
        </filters>
        <object>SvcCatalogReqExtdAttrVal</object>
        <outputAssignments>
            <assignToReference>SvcCatalogExtendedAttrValueStatus</assignToReference>
