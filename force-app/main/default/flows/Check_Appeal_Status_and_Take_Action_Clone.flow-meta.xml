    <recordLookups>
        <description>Gets the application form relation record with an Application Form ID matching ApplicationFormId. Stores the Reference Record ID of the result in the ProgramId variable.</description>
        <name>GetApplicationFormRelation</name>
        <label>Get Application Form Relation</label>
        <locationX>248</locationX>
        <locationY>350</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>GetProgram</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>ApplicationFormId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>applicationFormId</elementReference>
            </value>
        </filters>
        <object>ApplicationFormRelation</object>
        <outputAssignments>
            <assignToReference>ProgramId</assignToReference>
            <field>ReferenceRecordId</field>
        </outputAssignments>
        <sortField>Id</sortField>
        <sortOrder>Asc</sortOrder>
    </recordLookups>
    <recordLookups>
        <description>Get Most Recent Service Catalog Extended Attribute Values</description>
        <name>GetMostRecentServiceCatalogExtendedAttributeValues</name>
        <label>Get Most Recent Service Catalog Extended Attribute Values</label>
        <locationX>908</locationX>
        <locationY>890</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>AreAppealsFiledForApplicationForm</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>ReferenceRecordId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>applicationFormId</elementReference>
            </value>
        </filters>
        <filters>
            <field>SvcCtlgItemAttrDeveloperName</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>ApplicationForm</stringValue>
            </value>
        </filters>
        <object>SvcCatalogReqExtdAttrVal</object>
        <outputAssignments>
            <assignToReference>ServiceCatalogRequestId</assignToReference>
            <field>SvcCatalogRequestId</field>
        </outputAssignments>
        <sortField>CreatedDate</sortField>
        <sortOrder>Desc</sortOrder>
    </recordLookups>
    <recordLookups>
        <description>Gets the program record with an ID matching ProgramId. Stores the Application Appeal Limit of the result in the AppealLimit variable.</description>
        <name>GetProgram</name>
        <label>Get Program</label>
        <locationX>248</locationX>
        <locationY>458</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>SetAppealsFiledCount</targetReference>
