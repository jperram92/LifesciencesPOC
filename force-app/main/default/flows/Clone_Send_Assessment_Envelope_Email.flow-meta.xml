    <decisions>
        <description>Determines whether the request reference record is a care program site by checking if Request Reference ID of the record in Assessment Envelope from GetAssessmentEnvelopeRecord was set to True and starts with CareProgramSiteKeyPrefix.</description>
        <name>IsRequestReferenceRecordACareProgramSite</name>
        <label>Is Request Reference Record a Care Program Site?</label>
        <locationX>182</locationX>
        <locationY>782</locationY>
        <defaultConnector>
            <targetReference>GenerateSignatureLink</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>IsACareProgramSite</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>GetAssessmentEnvelopeRecord.RequestReferenceId</leftValueReference>
                <operator>WasSet</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>GetAssessmentEnvelopeRecord.RequestReferenceId</leftValueReference>
                <operator>StartsWith</operator>
                <rightValue>
                    <elementReference>CareProgramSiteKeyPrefix</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>SendAssessmentEmail</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
