        <locationX>534</locationX>
        <locationY>1769</locationY>
        <defaultConnectorLabel>No (Default)</defaultConnectorLabel>
        <rules>
            <name>IsApplicable</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>VerifyCommercialHealthInsurance.Outputs.isAppealApplicable</leftValueReference>
                <operator>EqualTo</operator>
            </conditions>
            <conditions>
                <leftValueReference>VerifyCommercialHealthInsurance.Outputs.isInsuranceTypeCommercial</leftValueReference>
                <operator>EqualTo</operator>
            </conditions>
            <conditions>
                <leftValueReference>Verify_Drug_Benefits.Outputs.isAppealApplicable</leftValueReference>
                <operator>EqualTo</operator>
