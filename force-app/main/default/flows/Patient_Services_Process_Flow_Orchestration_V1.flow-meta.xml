    <decisions>
        <description>Verifies whether the program applicant has commercial health insurance by checking if the isInsuranceTypeCommercial is True.</description>
        <name>HasCommercialInsurance</name>
        <label>Has Commercial Insurance?</label>
        <locationX>534</locationX>
        <locationY>803</locationY>
        <defaultConnector>
            <targetReference>Is_Appeal_Applicable</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No (Default)</defaultConnectorLabel>
        <rules>
            <name>HaveCommercialInsurance</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>VerifyCommercialHealthInsurance.Outputs.isInsuranceTypeCommercial</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Verify_Benefits</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <description>Determines whether an appeal is applicable for the VerifyCommercialHealthInsurance, VerifyDrugBenefits, or VerifyProgramEligibility steps.</description>
