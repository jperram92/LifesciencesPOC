    <assignments>
        <description>Adds 1 to the stepNumber variable.</description>
        <name>AssignStepNumber</name>
        <label>Assign Step Number</label>
        <locationX>182</locationX>
        <locationY>134</locationY>
        <assignmentItems>
            <assignToReference>stepNumber</assignToReference>
            <operator>Add</operator>
            <value>
                <numberValue>1.0</numberValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>GetAccount</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Sets ExceptionMessage to the message that the flow returns when there’s an error getting the account record.</description>
        <name>SetErrorMessage</name>
        <label>Set Error Message</label>
        <locationX>578</locationX>
        <locationY>350</locationY>
        <assignmentItems>
            <assignToReference>ExceptionMessage</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>$Flow.FaultMessage</stringValue>
            </value>
        </assignmentItems>
        <connector>
            <isGoTo>true</isGoTo>
            <targetReference>CreateProcessException</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Sets isPatientEligible to True.</description>
        <name>SetPatientEligibility</name>
        <label>Set Patient Eligibility</label>
        <locationX>50</locationX>
        <locationY>458</locationY>
        <assignmentItems>
            <assignToReference>isPatientEligible</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
    </assignments>
    <assignments>
        <description>Sets ExceptionMessage to PatientIneligibleMessageTextTemplate and isAppealApplicable to True.</description>
        <name>SetPatientIneligibleMessage</name>
        <label>Set Patient Ineligible Message</label>
        <locationX>314</locationX>
        <locationY>458</locationY>
        <assignmentItems>
            <assignToReference>ExceptionMessage</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>The patient isn&apos;t eligible for financial assistance. Verify if the patient resides in the US, is from Texas or Arizona, and is over 18 years old.</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>isAppealApplicable</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>CreateProcessException</targetReference>
        </connector>
    </assignments>
    <constants>
        <description>Stores the name of the state of Arizona.</description>
        <name>ArizonaState</name>
        <dataType>String</dataType>
        <value>
            <stringValue>Arizona</stringValue>
        </value>
    </constants>
    <constants>
        <description>Stores the country of the patient to be enrolled in a financial assistance program.</description>
        <name>EligibleCountry</name>
        <dataType>String</dataType>
        <value>
            <stringValue>US</stringValue>
        </value>
    </constants>
    <constants>
        <description>Stores the minimum eligible age for a patient to be enrolled in a financial assistance program.</description>
        <name>MinimumEligibleAge</name>
        <dataType>Number</dataType>
        <value>
            <numberValue>18.0</numberValue>
        </value>
    </constants>
    <constants>
        <description>Stores the name of the state of Texas</description>
        <name>TexasState</name>
        <dataType>String</dataType>
        <value>
            <stringValue>Texas</stringValue>
        </value>
    </constants>
    <decisions>
        <description>Determines whether the patient is eligible to be enrolled in a financial assistance program by checking if the account’s Billing Country matches EligibleCountry, Billing State/Province matches ArizonaState or TexasState, and PatientAgeFormula is greater than Age.</description>
        <name>IsPatientEligibleForFinancialAssistance</name>
        <label>Is Patient Eligible for Financial Assistance?</label>
        <locationX>182</locationX>
        <locationY>350</locationY>
        <defaultConnector>
            <targetReference>SetPatientIneligibleMessage</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No (Default)</defaultConnectorLabel>
        <rules>
            <name>IsEligible</name>
            <conditionLogic>1 AND (2 OR 3) AND 4</conditionLogic>
            <conditions>
                <leftValueReference>GetAccount.BillingCountry</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>EligibleCountry</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>GetAccount.BillingState</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>ArizonaState</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>GetAccount.BillingState</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>TexasState</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>PatientAgeFormula</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <elementReference>MinimumEligibleAge</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>SetPatientEligibility</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <description>Calculates the patient’s age.</description>
        <name>PatientAgeFormula</name>
        <dataType>Number</dataType>
        <expression>(TODAY() - {!GetAccount.PersonBirthdate})/365</expression>
        <scale>0</scale>
    </formulas>
    <interviewLabel>Patient Eligiblity Message {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Patient Eligiblity Message</label>
    <overriddenFlow>LsFinclAsst__CheckPatientEligibility</overriddenFlow>
