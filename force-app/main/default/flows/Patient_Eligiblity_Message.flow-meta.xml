    <recordCreates>
        <description>Creates a process exception record using the information passed into the flow. Stores the ID of the new process exception record in Process ExceptionId from CreateProcessException.</description>
        <name>CreateProcessException</name>
        <label>Create Process Exception</label>
        <locationX>314</locationX>
        <locationY>566</locationY>
        <connector>
