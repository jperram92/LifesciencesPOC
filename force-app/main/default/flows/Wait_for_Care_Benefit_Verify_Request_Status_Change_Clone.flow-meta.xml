    <decisions>
        <description>Determines whether a flow orchestration instance related object record was found by checking if the flowOrchestrationInstanceRelatedObjId variable contains a value.</description>
        <name>DoesFlowOrchInstanceRelatedObjectExist</name>
        <label>Does Flow Orchestration Instance Related Object Exist?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>CreateFlowOrchInstanceRelatedObj</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No (Default)</defaultConnectorLabel>
        <rules>
            <name>FlowOrchInstanceRelatedObjectExists</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>flowOrchestratorInstanceRelatedObjectId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>WaitForCareBenefitVerifyRequestStatusChange</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <interviewLabel>Wait for Care Benefit Verify Request Status Change Clone {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Wait for Care Benefit Verify Request Status Change Clone</label>
    <overriddenFlow>BnftVerfAgnt__WtCrBnftVrfyRqstStsChg</overriddenFlow>
    <processMetadataValues>
