    <waits>
        <description>Pause the flow until there&apos;s a change in the status of a care benefit verify request status changed event record, or times out after 30 days from the interview start time.</description>
        <name>WaitForCareBenefitVerifyRequestStatusChange</name>
        <label>Wait for Care Benefit Verify Request Status Change</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Other Care Benefit Verify Request ID Received (Default)</defaultConnectorLabel>
        <waitEvents>
            <name>InsuranceDetailsChanged</name>
            <conditionLogic>and</conditionLogic>
            <connector>
                <targetReference>saveBenVerfLogsInsuranceDetailsChanged</targetReference>
            </connector>
            <eventType>CareBnftVrfyRqstStsChgEvent</eventType>
            <inputParameters>
                <name>RecordIdentifier</name>
                <value>
                    <elementReference>careBenefitVerifyRequestId</elementReference>
                </value>
            </inputParameters>
            <inputParameters>
                <name>Status</name>
                <value>
                    <elementReference>InsuranceDetailsChangeDetectedInPatientAssessmentResponseEvent</elementReference>
                </value>
            </inputParameters>
            <label>Insurance Details Changed</label>
        </waitEvents>
        <waitEvents>
            <name>isMatchingCareBenefitVerifyRequestIdAndStatusReceived</name>
            <conditionLogic>and</conditionLogic>
            <connector>
                <targetReference>SetResumeEventVariableSuccess</targetReference>
            </connector>
            <eventType>CareBnftVrfyRqstStsChgEvent</eventType>
            <inputParameters>
                <name>RecordIdentifier</name>
                <value>
                    <elementReference>careBenefitVerifyRequestId</elementReference>
                </value>
            </inputParameters>
            <inputParameters>
                <name>Status</name>
                <value>
                    <elementReference>careBenefitVerifyRequestStatus</elementReference>
                </value>
            </inputParameters>
            <label>Matching Care Benefit Verify Request ID and Status Received</label>
        </waitEvents>
        <waitEvents>
            <name>NoChangesInPatientDetails</name>
            <conditionLogic>and</conditionLogic>
            <connector>
                <targetReference>saveBenVerfLogsNoChangesInPatientDetails</targetReference>
            </connector>
            <eventType>CareBnftVrfyRqstStsChgEvent</eventType>
            <inputParameters>
                <name>RecordIdentifier</name>
                <value>
                    <elementReference>careBenefitVerifyRequestId</elementReference>
                </value>
            </inputParameters>
            <inputParameters>
                <name>Status</name>
                <value>
                    <elementReference>NoChangesInPatientAssessmentResponseEvent</elementReference>
                </value>
            </inputParameters>
            <label>No Changes In Patient Details</label>
        </waitEvents>
        <waitEvents>
            <name>WaitTimesOut</name>
            <conditionLogic>and</conditionLogic>
            <connector>
                <targetReference>saveBenVerfLogs</targetReference>
            </connector>
            <eventType>AlarmEvent</eventType>
            <inputParameters>
                <name>AlarmTime</name>
                <value>
                    <elementReference>$Flow.InterviewStartTime</elementReference>
                </value>
            </inputParameters>
            <inputParameters>
                <name>TimeOffset</name>
                <value>
                    <numberValue>30.0</numberValue>
                </value>
            </inputParameters>
            <inputParameters>
                <name>TimeOffsetUnit</name>
                <value>
                    <stringValue>Days</stringValue>
                </value>
            </inputParameters>
            <label>Wait Times Out</label>
        </waitEvents>
    </waits>
</Flow>
