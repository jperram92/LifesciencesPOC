    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <description>Creates a Flow Orchestration Instance Related obj record, setting the Flow Orchestration Instance ID to the orchestratorInstanceId input variable, the Related Object ID to the careBenefitVerifyRequestId input variable, and the Status to InProgress. Stores the ID of the new record in the flowOrchestrationInstanceRelatedObjId variable.</description>
        <name>CreateFlowOrchInstanceRelatedObj</name>
        <label>Create Flow Orchestration Instance Related Obj</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignRecordIdToReference>flowOrchestratorInstanceRelatedObjectId</assignRecordIdToReference>
        <connector>
            <targetReference>WaitForCareBenefitVerifyRequestStatusChange</targetReference>
        </connector>
        <inputAssignments>
            <field>FlowOrchestrationInstanceId</field>
            <value>
                <elementReference>orchestratorInstanceId</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>RelatedObjectId</field>
            <value>
                <elementReference>careBenefitVerifyRequestId</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Status</field>
            <value>
                <stringValue>InProgress</stringValue>
            </value>
        </inputAssignments>
        <object>FlowOrchestrationInstRelaObj</object>
    </recordCreates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>DoesFlowOrchInstanceRelatedObjectExist</targetReference>
        </connector>
    </start>
    <status>Active</status>
    <textTemplates>
        <description>Stores the text template that contains the message that’s displayed to the flow user when the patient’s insurance details are changed and a new benefits verification request should be created.</description>
        <name>InitiateNewVerificationRequestTextTemplate</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>Terminated::Initiate a new verification request.</text>
    </textTemplates>
    <textTemplates>
        <description>Stores the text template that contains the message that’s displayed to the flow user when there are no changes to patient details and the care benefits verify request status should be marked as Completed.</description>
        <name>UpdateBenefitsRequestStatusAsCompletedTextTemplate</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>Terminated::Mark the request as complete, or initiate benefits reverification.</text>
    </textTemplates>
    <textTemplates>
        <description>Stores the text template that contains the message that’s displayed to the flow user when the wait is timed out.</description>
        <name>WaitTimeoutErrorTextTemplate</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>Failed::{!timeoutMessage}</text>
    </textTemplates>
