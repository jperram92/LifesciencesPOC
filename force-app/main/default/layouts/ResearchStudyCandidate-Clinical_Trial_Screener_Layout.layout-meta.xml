<?xml version="1.0" encoding="UTF-8"?>
<Layout xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>ResearchStudyCandidate-Clinical_Trial_Screener_Layout</fullName>

    <quickActionList>
        <quickActionListItems>
            <quickActionName>FeedItem.TextPost</quickActionName>
        </quickActionListItems>
    </quickActionList>

    <layoutSections>
        <!-- ── Section 1: Candidate Overview ── -->
        <customLabel>false</customLabel>
        <detailHeading>true</detailHeading>
        <editHeading>true</editHeading>
        <label>Candidate Overview</label>
        <layoutColumns>
            <layoutItems>
                <behavior>Required</behavior>
                <field>CandidateId</field>
            </layoutItems>
            <layoutItems>
                <behavior>Required</behavior>
                <field>ResearchStudyId</field>
            </layoutItems>
            <layoutItems>
                <behavior>Edit</behavior>
                <field>CareProgramSiteId</field>
            </layoutItems>
            <layoutItems>
                <behavior>Edit</behavior>
                <field>Status</field>
            </layoutItems>
        </layoutColumns>
        <layoutColumns>
            <layoutItems>
                <behavior>Edit</behavior>
                <field>SourceType</field>
            </layoutItems>
            <layoutItems>
                <behavior>Edit</behavior>
                <field>DropoutProbabilityScore</field>
            </layoutItems>
            <layoutItems>
                <behavior>Edit</behavior>
                <field>MatchedInclusionCritCount</field>
            </layoutItems>
            <layoutItems>
                <behavior>Edit</behavior>
                <field>MatchedExclusionCritCount</field>
            </layoutItems>
        </layoutColumns>
        <style>TwoColumnsTopToBottom</style>
    </layoutSections>

    <layoutSections>
        <!-- ── Section 2: Eligibility Screener (GxP) ── -->
        <customLabel>false</customLabel>
        <detailHeading>true</detailHeading>
        <editHeading>true</editHeading>
        <label>Eligibility Screener (GxP)</label>
        <layoutColumns>
            <layoutItems>
                <behavior>Required</behavior>
                <field>Eligibility_Status__c</field>
            </layoutItems>
            <layoutItems>
                <behavior>Edit</behavior>
                <field>Protocol_Failure_Code__c</field>
            </layoutItems>
            <layoutItems>
                <behavior>Readonly</behavior>
                <field>Submission_Timestamp__c</field>
            </layoutItems>
            <layoutItems>
                <behavior>Readonly</behavior>
                <field>Screener_Version__c</field>
            </layoutItems>
        </layoutColumns>
        <layoutColumns>
            <layoutItems>
                <behavior>Edit</behavior>
                <field>Disqualification_Reason__c</field>
            </layoutItems>
        </layoutColumns>
        <style>TwoColumnsTopToBottom</style>
    </layoutSections>

    <layoutSections>
        <!-- ── Section 3: Screener Audit Trail ── -->
        <customLabel>false</customLabel>
        <detailHeading>true</detailHeading>
        <editHeading>false</editHeading>
        <label>Screener Audit Trail (Read-Only)</label>
        <layoutColumns>
            <layoutItems>
                <behavior>Readonly</behavior>
                <field>Screener_JSON_Responses__c</field>
            </layoutItems>
        </layoutColumns>
        <layoutColumns/>
        <style>TwoColumnsTopToBottom</style>
    </layoutSections>

    <layoutSections>
        <!-- ── Section 4: System Information ── -->
        <customLabel>false</customLabel>
        <detailHeading>true</detailHeading>
        <editHeading>false</editHeading>
        <label>System Information</label>
        <layoutColumns>
            <layoutItems>
                <behavior>Readonly</behavior>
                <field>IsAutomaticEvaluationCmpl</field>
            </layoutItems>
            <layoutItems>
                <behavior>Readonly</behavior>
                <field>SourceSystem</field>
            </layoutItems>
            <layoutItems>
                <behavior>Readonly</behavior>
                <field>SourceSystemIdentifier</field>
            </layoutItems>
        </layoutColumns>
        <layoutColumns>
            <layoutItems>
                <behavior>Readonly</behavior>
                <field>SourceSystemModified</field>
            </layoutItems>
        </layoutColumns>
        <style>TwoColumnsTopToBottom</style>
    </layoutSections>

    <showEmailCheckbox>false</showEmailCheckbox>
    <showHighlightsPanel>true</showHighlightsPanel>
    <showInteractionLogPanel>false</showInteractionLogPanel>
    <showRunAssignmentRulesCheckbox>false</showRunAssignmentRulesCheckbox>
    <showSolutionSection>false</showSolutionSection>
    <showSubmitAndAttachButton>false</showSubmitAndAttachButton>
</Layout>
